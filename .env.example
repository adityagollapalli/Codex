DOCUMIND_ENVIRONMENT=development
DOCUMIND_HOST=0.0.0.0
DOCUMIND_PORT=8000
DOCUMIND_LOG_LEVEL=INFO

# Runtime storage
DOCUMIND_DATA_DIR=data

# Retrieval
DOCUMIND_CHUNK_SIZE_WORDS=180
DOCUMIND_CHUNK_OVERLAP_WORDS=40
DOCUMIND_RETRIEVAL_TOP_K=4
DOCUMIND_EMBEDDING_BACKEND=hash
DOCUMIND_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
DOCUMIND_VECTOR_BACKEND=simple
DOCUMIND_VECTOR_COLLECTION_NAME=documind_chunks

# Optional OpenAI integration for answer synthesis and summarization.
# Install requirements-ai.txt and switch to:
# DOCUMIND_EMBEDDING_BACKEND=sentence-transformer
# DOCUMIND_VECTOR_BACKEND=chroma
DOCUMIND_OPENAI_API_KEY=
DOCUMIND_OPENAI_MODEL=gpt-4o-mini
